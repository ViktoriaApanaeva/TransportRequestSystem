@model List<TransportRequestSystem.Models.User>
@{
    ViewData["Title"] = "Управление пользователями";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_Navbar")

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Управление пользователями</h1>
            <a href="@Url.Action("Create")" class="btn btn-base">
                <i class="bi bi-person-plus"></i> Создать
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Логин</th>
                        <th>ФИО</th>
                        <th>Телефон</th>
                        <th>Роль</th>
                        <th>Статус</th>
                        <th style="border-right:none !important">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Username</td>
                            <td>@user.FullName</td>
                            <td>@(user.Phone ?? "-")</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Dispatcher" ? "bg-warning" : "bg-secondary")">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                                    @(user.IsActive ? "Активен" : "Заблокирован")
                                </span>
                            </td>
                            <td style="border-right:none !important">
                                <a href="@Url.Action("Edit", new { id = user.Id })" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (user.Username != User.Identity?.Name)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="deleteUser(@user.Id, '@user.Username')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <form id="deleteForm" method="post" action="@Url.Action("Delete")">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteId" />
    </form>

    <script>
        function deleteUser(id, username) {
            if (confirm(`Удалить пользователя "${username}"?`)) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
</body>
</html>