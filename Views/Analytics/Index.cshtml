@model List<TransportRequestSystem.Models.Application>
@using TransportRequestSystem.Models
@{
    ViewData["Title"] = "Аналитика и отчеты";
    var dateFrom = ViewBag.DateFrom as DateTime? ?? DateTime.Today.AddDays(-30);
    var dateTo = ViewBag.DateTo as DateTime? ?? DateTime.Today;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <link rel="stylesheet" href="~/css/analytics.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <style>
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
            color: white;
        }
    </style>
</head>
<body>
    <!-- Навигация -->
    @await Html.PartialAsync("_Navbar")
    
    <!-- Основной контент -->
    <div class="container mt-4 main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Аналитика и отчеты</h1>
            <div class="d-flex gap-2">
                <a href="@Url.Action("ExportSimple", "Analytics", new { 
                        dateFrom = ViewBag.DateFrom?.ToString("yyyy-MM-dd"), 
                        dateTo = ViewBag.DateTo?.ToString("yyyy-MM-dd") 
                    })" class="btn btn-base">
                        Отчёт xlsx
                </a>
            </div>
        </div>

        <!-- Фильтр по дате -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Дата с</label>
                        <input type="date" name="dateFrom" class="form-control" value="@dateFrom.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Дата по</label>
                        <input type="date" name="dateTo" class="form-control" value="@dateTo.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-base me-2">Применить</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Карточки с основными показателями -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="stat-card">
                    <h2>@ViewBag.TotalApps</h2>
                    <p>Всего заявок</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <h2>@ViewBag.AvgTime ч</h2>
                    <p>Среднее время</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <h2>@Model.Count(a => a.Status == ApplicationStatus.Completed)</h2>
                    <p>Выполнено</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <h2>@Model.Count(a => a.Status == ApplicationStatus.InProgress)</h2>
                    <p>В работе</p>
                </div>
            </div>
        </div>

        <!-- Графики -->
        <div class="row">
            <div class="col-md-8 mb-4">
                <div class="card">
                    <div class="card-header">
                        Динамика заявок по дням
                    </div>
                    <div class="card-body">
                        <canvas id="dailyChart" height="300"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        Статусы
                    </div>
                    <div class="card-body">
                        <canvas id="statusChart" height="300"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                       Последние заявки
                    </div>
                    <div class="card-body" style="max-height: 285px; overflow-y: auto;">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>№</th>
                                    <th>Дата</th>
                                    <th style="border-right:none !important">Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.OrderByDescending(a => a.CreatedAt).Take(10))
                                {
                                    <tr>
                                        <td>@app.Number</td>
                                        <td>@app.CreatedAt.ToString("dd.MM.yyyy")</td>
                                        <td style="border-right:none !important">
                                            <span class="status-badge" style="background-color: @GetStatusColor(app.Status);">
                                                @GetStatusName(app.Status)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                       Средняя загрузка по видам транспорта
                    </div>
                    <div class="card-body">
                        <canvas id="vehicleTypeChart" height="250"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // График 1: Динамика заявок по дням
        const dailyCtx = document.getElementById('dailyChart').getContext('2d');
        new Chart(dailyCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", ((Dictionary<string, int>)ViewBag.DailyStats).Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'Количество заявок',
                    data: [@string.Join(",", ((Dictionary<string, int>)ViewBag.DailyStats).Values)],
                    borderColor: '#008EB9',
                    backgroundColor: 'rgba(0, 142, 185, 0.1)',
                    tension: 0.1,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // График 2: Распределение по статусам 
        const statusCtx = document.getElementById('statusChart').getContext('2d');

        // Хронологический порядок статусов с цветами
        const statusOrder = [
            { key: 'Создана', color: '#dd8827', label: 'Создана' },
            { key: 'Утверждена', color: '#28a745', label: 'Утверждена' },
            { key: 'Назначено ТС', color: '#17a2b8', label: 'Назначено ТС' },
            { key: 'Исполняется', color: '#008EB9', label: 'Исполняется' },
            { key: 'Исполнена', color: '#20c997', label: 'Исполнена' },
            { key: 'Не исполнена', color: '#ffc107', label: 'Не исполнена' },
            { key: 'Отменена', color: '#6c757d', label: 'Отменена' },
            { key: 'Удалена', color: '#dc3545', label: 'Удалена' }
        ];

        // Маппинг исходных статусов в группы
        const statusMapping = {
            'Создана': 'Создана',
            'Создана/Изменена': 'Создана',
            'Утверждена': 'Утверждена',
            'Назначено ТС': 'Назначено ТС',
            'Исполняется': 'Исполняется',
            'Исполнена': 'Исполнена',
            'Не исполнена': 'Не исполнена',
            'Отклонена диспетчером': 'Отменена',
            'Отклонена руководителем': 'Отменена',
            'Удалена': 'Удалена'
        };

        const rawStatusData = @Html.Raw(Json.Serialize(ViewBag.StatusStats));
        const groupedData = {};

        for (const [key, value] of Object.entries(rawStatusData)) {
            const mappedKey = statusMapping[key] || key;
            groupedData[mappedKey] = (groupedData[mappedKey] || 0) + value;
        }

        const chartLabels = [];
        const chartData = [];
        const chartColors = [];

        for (const status of statusOrder) {
            const count = groupedData[status.key] || 0;
            chartLabels.push(status.label);
            chartData.push(count);
            chartColors.push(status.color);
        }

        new Chart(statusCtx, {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Количество заявок',
                    data: chartData,
                    backgroundColor: chartColors,
                    borderRadius: 5,
                    barPercentage: 0.7
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `Количество: ${context.raw} заявок`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Количество заявок',
                            font: { weight: 'bold', size: 12 }
                        }
                    },
                    y: {
                        title: {
                            display: true,
                            text: 'Статус',
                            font: { weight: 'bold', size: 12 }
                        },
                        grid: { display: false }
                    }
                }
            }
        });

        // График 3: Средняя загрузка по видам транспорта
        const vehicleTypeCtx = document.getElementById('vehicleTypeChart').getContext('2d');
        new Chart(vehicleTypeCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.VehicleTypeStats.Keys)),
                datasets: [{
                    label: 'Среднее количество заявок в день',
                    data: @Html.Raw(Json.Serialize(ViewBag.VehicleTypeStats.Values)),
                    backgroundColor: '#008EB9',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `Среднее: ${context.raw} заявок в день`;
                            }
                        }
                    }
                }
            }
        });


    </script>
</body>
</html>

@functions {
    public string GetStatusName(ApplicationStatus status)
    {
        return status switch
        {
            ApplicationStatus.CreatedOrModified => "Создана",
            ApplicationStatus.Approved => "Утверждена",
            ApplicationStatus.InProgress => "Исполняется",
            ApplicationStatus.Completed => "Исполнена",
            ApplicationStatus.RejectedByDispatcher => "Отменена",
            ApplicationStatus.RejectedByDirector => "Отменена",
            ApplicationStatus.AssignedToVehicle => "Назначено ТС",
            ApplicationStatus.NotCompleted => "Не исполнена",
            ApplicationStatus.Deleted => "Удалена",
            _ => status.ToString()
        };
    }

    public string GetStatusColor(ApplicationStatus status)
    {
        return status switch
        {
            ApplicationStatus.CreatedOrModified => "#dd8827",
            ApplicationStatus.Approved => "#28a745",
            ApplicationStatus.AssignedToVehicle => "#17a2b8",
            ApplicationStatus.InProgress => "#008EB9",
            ApplicationStatus.Completed => "#20c997",
            ApplicationStatus.NotCompleted => "#ffc107",
            ApplicationStatus.RejectedByDispatcher => "#6c757d",
            ApplicationStatus.RejectedByDirector => "#6c757d",
            ApplicationStatus.Deleted => "#dc3545",
            _ => "#6c757d"
        };
    }
}