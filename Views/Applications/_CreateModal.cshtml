@using Microsoft.AspNetCore.Identity
@using TransportRequestSystem.Models

@{
    var isDispatcher = User.IsInRole("Dispatcher");
}
<link rel="stylesheet" href="~/css/modal.css" asp-append-version="true" />

<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white">
                <h5 class="modal-title fw-bold" id="createModalLabel">СОЗДАНИЕ ЗАЯВКИ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Applications/Create" method="post" enctype="multipart/form-data" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <input type="hidden" name="actionType" id="actionType" value="save" />
                    <input type="hidden" name="Id" value="0" />
                    <input type="hidden" name="Number" value="@Model.Number" />
                    <input type="hidden" name="Status" value="CreatedOrModified" />
                    
                    <div class="row">
                        <!-- Раздел заказчика - видят все -->
                        <div class="col-6 mb-3 border rounded p-3">
                            <h6 class="fw-bold text-primary mb-3">Раздел заказчика</h6>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-bold">Дата</label>
                                    <input name="ApplicationDate" type="date" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Начало поездки</label>
                                    <input name="TripStart" type="datetime-local" class="form-control">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Окончание поездки</label>
                                    <input name="TripEnd" type="datetime-local" class="form-control">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Орг.ед.</label>
                                    <input name="OrganizationUnit" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">ФИО ответственного</label>
                                    <input name="ResponsiblePerson" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Телефон</label>
                                    <input name="Phone" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Цель поездки</label>
                                    <input name="Purpose" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label fw-normal">Кол-во пассажиров</label>
                                    <input name="Passengers" class="form-control">
                                </div>
                                <div class="col-12 mb-2">
                                    <label class="form-label fw-normal">Маршрут</label>
                                    <textarea name="Route" class="form-control" rows="1" required></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-normal">Примечание</label>
                                    <textarea name="Notes" class="form-control" rows="1"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Раздел диспетчера - видят только диспетчеры -->
                        @if (isDispatcher)
                        {
                            <div class="col-6 mb-3 border rounded p-3">
                                <h6 class="fw-bold text-primary mb-3">Раздел диспетчера</h6>
                                <div class="row">
                                    <div class="col-md-12 mb-2">
                                        <label class="form-label fw-normal">ФИО диспетчера</label>
                                        <select name="DispatcherName" id="DispatcherName" class="form-select">
                                            <option value="">— Выберите диспетчера —</option>
                                            @if (ViewBag.Dispatchers != null)
                                            {
                                                foreach (var d in ViewBag.Dispatchers)
                                                {
                                                    <option value="@d.FullName" data-phone="@d.Phone">@d.FullName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-12 mb-2">
                                        <label class="form-label fw-normal">Телефон диспетчера</label>
                                        <input name="DispatcherPhone" id="DispatcherPhone" class="form-control" readonly>
                                    </div>

                                    <div class="col-md-12 mb-2">
                                        <label class="form-label fw-normal">ФИО водителя</label>
                                        <select name="DriverName" id="DriverName" class="form-select">
                                            <option value="">— Выберите водителя —</option>
                                            @if (ViewBag.Drivers != null)
                                            {
                                                foreach (var d in ViewBag.Drivers)
                                                {
                                                    <option value="@d.FullName" data-phone="@d.Phone">@d.FullName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-12 mb-2">
                                        <label class="form-label fw-normal">Телефон водителя</label>
                                        <input name="DriverPhone" id="DriverPhone" class="form-control" readonly>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <label class="form-label fw-normal">Марка ТС</label>
                                        <input name="VehicleBrand" class="form-control">
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <label class="form-label fw-normal">Гос. номер</label>
                                        <input name="VehicleNumber" class="form-control">
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <label class="form-label fw-normal">Цвет ТС</label>
                                        <input name="VehicleColor" class="form-control">
                                    </div>
                                    <div class="col-12 mb-2">
                                        <label class="form-label fw-normal">Примечание диспетчера</label>
                                        <textarea name="DispatcherNotes" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Если пользователь не диспетчер, показываем заглушку -->
                            <div class="col-6 mb-3 border rounded p-3 bg-light">
                                <h6 class="fw-bold text-muted mb-3">Раздел диспетчера</h6>
                                <div class="text-center text-muted py-5">
                                    <p class="mt-2">Доступно только диспетчерам</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-based" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-based" onclick="document.getElementById('actionType').value='save'">Сохранить</button>
                    
                    @if (isDispatcher)
                    {
                        <button type="submit" class="btn btn-based" onclick="document.getElementById('actionType').value='approve'">Утвердить</button>
                        <button type="submit" class="btn btn-based" onclick="document.getElementById('actionType').value='reject'">Отклонить</button>
                    }
                </div>
            </form>
        </div>
    </div>
    <script>
        // Автозаполнение телефона при выборе диспетчера
        var dispatcherSelect = document.getElementById('DispatcherName');
        if (dispatcherSelect) {
            dispatcherSelect.addEventListener('change', function() {
                var selected = this.options[this.selectedIndex];
                var phone = selected.getAttribute('data-phone') || '';
                document.getElementById('DispatcherPhone').value = phone;
            });
        }

        // Автозаполнение телефона при выборе водителя
        var driverSelect = document.getElementById('DriverName');
        if (driverSelect) {
            driverSelect.addEventListener('change', function() {
                var selected = this.options[this.selectedIndex];
                var phone = selected.getAttribute('data-phone') || '';
                document.getElementById('DriverPhone').value = phone;
            });
        }
    </script>
</div>
