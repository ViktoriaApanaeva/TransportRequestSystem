@model List<TransportRequestSystem.Models.Application>
@using TransportRequestSystem.Models
@using TransportRequestSystem.Pages.Applications
@using System.Linq

@{
    ViewData["Title"] = "Управление заявками";
    var filter = ViewBag.Filter as ApplicationFilter ?? new ApplicationFilter();
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/applications.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Навигация -->
    <nav class="navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <!-- Левые кнопки -->
            <div class="d-flex flex-wrap" style="gap: 10px;">
                <a href="/" class="nav-btn">Управление заявками</a>
                <a href="/analytics" class="nav-btn">Аналитика</a>
                <a href="/create" class="nav-btn">Подать заявку</a>
            </div>

            <!-- Правая часть - пользователь -->
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="text-white small">@User.Identity.Name</span>
                    <a href="/Account/Logout" class="btn btn-sm"
                       style="background-color: #C09C6A; color: white; border-radius: 10px;">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-sm"
                       style="background-color: #C09C6A; color: white; border-radius: 10px;">
                        <i class="bi bi-box-arrow-in-right"></i> Войти
                    </a>
                }
            </div>
        </div>
    </nav>
    <!-- Основной контент -->
    <div class="container mt-4">
        <!-- Шапка с заголовком и поиском -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Управление заявками</h1>
            <div class="d-flex gap-2">
                <!-- Поиск -->
                <div class="input-group" style="width: 300px;">
                    <input type="text" class="form-control" placeholder="Поиск..." id="searchInput">
                    <button class="btn searchButton" type="button" id="searchButton">
                        Поиск
                    </button>
                </div>

                <!-- Кнопка создания -->
                <button type="button" class="btn btn-base"
                        data-bs-toggle="modal"
                        data-bs-target="#createModal">
                    Создать заявку
                </button>
            </div>
        </div>

        <!-- Фильтры -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" asp-action="Index" autocomplete="off">
                    <div class="row">
                        <!-- Фильтр по дате -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Дата</label>
                            <input type="date" name="DateFrom" class="form-control mb-2" value="@filter.DateFrom?.ToString("yyyy-MM-dd")">
                            <input type="date" name="DateTo" class="form-control" value="@filter.DateTo?.ToString("yyyy-MM-dd")">
                        </div>

                        <!-- Фильтр по организации -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Организация</label>
                            <input type="text" name="OrganizationUnit" class="form-control" value="@filter.OrganizationUnit">
                        </div>

                        <div class="col-md-6 mb-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-base">Обновить</button>
                        <button type="button"
                                class="btn btn-base"
                                style="background-color:grey;"
                                onclick="resetFilters()">
                            Сбросить
                        </button>
                        </div>
                    </div>
                    

                    <!-- Фильтр по статусам -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <label class="fw-bold">Статус</label>
                                    <button type="button"
                                            class="btn btn-base ms-4"
                                            style="width:70px !important; height: 30px !important;"
                                            onclick="selectAllStatuses()">
                                        Все
                                    </button>
                            </div>
                            <div class="row">
                                @{
                                    var statusGroups = Enum.GetValues<ApplicationStatus>().Chunk(3).ToList();
                                }
                                @foreach (var group in statusGroups)
                                {
                                    <div class="col-md-4">
                                        @foreach (var status in group)
                                        {
                                            var isChecked = filter.SelectedStatuses?.Contains(status) ?? true;
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="SelectedStatuses" value="@status"
                                                       id="status_@status" @(isChecked ? "checked" : "")>
                                                <label class="form-check-label" for="status_@status">
                                                    @IndexModel.GetDisplayName(status)
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>   
                        </div>
                    </div>
                </form>
            </div>
        </div> 
        <!-- Таблица заявок -->
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Дата</th>
                            <th>Орг. ед.</th>
                            <th>Ответственный</th>
                            <th>Цель</th>
                            <th>Маршрут</th>
                            <th>Статус</th>
                            <th style="border-right:none !important"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td>@app.Number</td>
                                <td>@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                                <td>@app.OrganizationUnit</td>
                                <td>@app.ResponsiblePerson</td>
                                <td>@app.Purpose</td>
                                <td>@app.Route</td>
                                <td>
                                    <span class="badge @IndexModel.GetStatusBadgeClass(app.Status)">@IndexModel.GetDisplayName(app.Status)</span>
                                </td>
                                <td style="border-right:none !important">
                                    <a href="#" class="btn btn-sm btn-outline-primary"
                                       onclick="loadApplication(@app.Id)" title="Редактировать">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Заявок не найдено. <a href="#" data-bs-toggle="modal" data-bs-target="#createModal">Создайте первую</a>.
            </div>
        }
    </div>

    <!-- Модальное окно для создания/редактирования -->
    @{
        await Html.RenderPartialAsync("_CreateModal", new Application
        {
            Number = Application.GenerateNumber(),
            ApplicationDate = DateTime.Today,
            Status = ApplicationStatus.CreatedOrModified
        });
    }

    <script>
        function resetFilters() {
            // Очищаем поля дат и организации
            document.querySelector('input[name="DateFrom"]').value = '';
            document.querySelector('input[name="DateTo"]').value = '';
            document.querySelector('input[name="OrganizationUnit"]').value = '';

            // Сбрасываем все чекбоксы статусов
            document.querySelectorAll('input[name="SelectedStatuses"]').forEach(cb => cb.checked = false);

            // Отправляем форму
            document.querySelector('form').submit();
        }

        function selectAllStatuses() {
            // Отмечаем все чекбоксы статусов
            document.querySelectorAll('input[name="SelectedStatuses"]').forEach(cb => cb.checked = true);
            let selectAllInput = document.querySelector('input[name="selectAll"]');
            if (!selectAllInput) {
                selectAllInput = document.createElement('input');
                selectAllInput.type = 'hidden';
                selectAllInput.name = 'selectAll';
                selectAllInput.value = 'true';
                document.querySelector('form').appendChild(selectAllInput);
            } else {
                selectAllInput.value = 'true';
            }
            // Отправляем форму
            document.querySelector('form').submit();
        }

        // Клиентский поиск по таблице
        document.getElementById('searchButton').onclick = filterTable;
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') filterTable();
        });

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(search) ? '' : 'none';
            });
        }

                function loadApplication(id) {
            fetch('/Applications/Edit/' + id)
                .then(response => response.json())
                .then(data => {

                    // Соответствие между полями JSON и полями формы
                    const fieldMapping = {
                        // JSON поле : Имя поля в форме
                        'number': 'Number',
                        'applicationDate': 'ApplicationDate',
                        'tripStart': 'TripStart',
                        'tripEnd': 'TripEnd',
                        'organizationUnit': 'OrganizationUnit',
                        'responsiblePerson': 'ResponsiblePerson',
                        'phone': 'Phone',
                        'purpose': 'Purpose',
                        'route': 'Route',
                        'passengers': 'Passengers',
                        'notes': 'Notes',
                        'dispatcherName': 'DispatcherName',
                        'dispatcherPhone': 'DispatcherPhone',
                        'driverName': 'DriverName',
                        'driverPhone': 'DriverPhone',
                        'vehicleBrand': 'VehicleBrand',
                        'vehicleNumber': 'VehicleNumber',
                        'vehicleColor': 'VehicleColor',
                        'dispatcherNotes': 'DispatcherNotes'
                    };

                    // Заполняем поля формы
                    Object.keys(fieldMapping).forEach(jsonField => {
                        const formFieldName = fieldMapping[jsonField];
                        const input = document.querySelector(`#createModal [name="${formFieldName}"]`);

                        if (input) {
                            // Преобразуем даты в формат для input
                            let value = data[jsonField];

                            if (jsonField.includes('Date') || jsonField.includes('trip')) {
                                if (value) {
                                    // Для date input нужно только YYYY-MM-DD
                                    if (input.type === 'date') {
                                        value = value.split('T')[0];
                                    }
                                    // Для datetime-local нужно YYYY-MM-DDTHH:MM
                                    else if (input.type === 'datetime-local') {
                                        value = value.replace('Z', '').slice(0, 16);
                                    }
                                }
                            }

                            input.value = value || '';
                        } else {
                            console.log(`Поле ${formFieldName} не найдено в форме!`);
                        }
                    });

                    // Устанавливаем action формы для редактирования
                    const form = document.querySelector('#createModal form');
                    form.action = '/Applications/Edit/' + id;
                    form.method = 'post';

                    // Добавляем скрытое поле с ID
                    let idInput = form.querySelector('input[name="Id"]');
                    if (!idInput) {
                        idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'Id';
                        form.appendChild(idInput);
                    }
                    idInput.value = id;

                    // Меняем заголовок модального окна
                    const modalTitle = document.querySelector('#createModal .modal-title');
                    if (modalTitle) {
                        modalTitle.textContent = 'Редактирование заявки №' + data.number;
                    }

                    new bootstrap.Modal(document.getElementById('createModal')).show();
                })
                .catch(error => {
                    console.error('Ошибка:', error);
                    alert('Не удалось загрузить данные заявки');
                });
        }
    </script>
</body>
</html>

