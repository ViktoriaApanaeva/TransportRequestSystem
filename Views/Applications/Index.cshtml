@model List<TransportRequestSystem.Models.Application>
@using TransportRequestSystem.Models
@using TransportRequestSystem.Pages.Applications
@using System.Linq

@{
    ViewData["Title"] = "Управление заявками";
    var filter = ViewBag.Filter as ApplicationFilter ?? new ApplicationFilter();
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/applications.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
</head>
<body>
    <!-- Навигация -->
    @await Html.PartialAsync("_Navbar")
    <!-- Основной контент -->
    <div class="container mt-4">
        <!-- Шапка с заголовком и поиском -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Управление заявками</h1>
            <div class="d-flex gap-2">
                <!-- Поиск -->
                <div class="input-group" style="width: 300px;">
                    <input type="text" class="form-control" placeholder="Поиск..." id="searchInput">
                    <button class="btn searchButton" type="button" id="searchButton">
                        Поиск
                    </button>
                </div>

                <!-- Кнопка создания -->
                <button type="button" class="btn btn-base"
                        data-bs-toggle="modal"
                        data-bs-target="#createModal">
                    Создать заявку
                </button>
            </div>
        </div>

        <!-- Фильтры -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" asp-action="Index" autocomplete="off">
                    <div class="row">
                        <!-- Фильтр по дате -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Дата</label>
                            <input type="date" name="DateFrom" class="form-control mb-2" value="@filter.DateFrom?.ToString("yyyy-MM-dd")">
                            <input type="date" name="DateTo" class="form-control" value="@filter.DateTo?.ToString("yyyy-MM-dd")">
                        </div>

                        <!-- Фильтр по организации -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Орг. ед.</label>
                            <input type="text" name="OrganizationUnit" class="form-control" value="@filter.OrganizationUnit">
                        </div>

                        <div class="col-md-6 mb-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-base">Обновить</button>
                        <button type="button"
                                class="btn btn-base"
                                style="background-color:grey;"
                                onclick="resetFilters()">
                            Сбросить
                        </button>
                        </div>
                    </div>
                    

                    <!-- Фильтр по статусам -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <label class="fw-bold">Статус</label>
                                    <button type="button"
                                            class="btn btn-base ms-4"
                                            style="width:70px !important; height: 30px !important;"
                                            onclick="selectAllStatuses()">
                                        Все
                                    </button>
                            </div>
                            <div class="row">
                                @{
                                    var statusGroups = Enum.GetValues<ApplicationStatus>().Chunk(3).ToList();
                                }
                                @foreach (var group in statusGroups)
                                {
                                    <div class="col-md-4">
                                        @foreach (var status in group)
                                        {
                                            var isChecked = filter.SelectedStatuses?.Contains(status) ?? true;
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="SelectedStatuses" value="@status"
                                                       id="status_@status" @(isChecked ? "checked" : "")>
                                                <label class="form-check-label" for="status_@status">
                                                    @IndexModel.GetDisplayName(status)
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>   
                        </div>
                    </div>
                </form>
            </div>
        </div> 
        <!-- Таблица заявок -->
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Дата</th>
                            <th>Орг. ед.</th>
                            <th>Ответственный</th>
                            <th>Цель</th>
                            <th>Маршрут</th>
                            <th>Статус</th>
                            <th style="border-right:none !important"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td>@app.Number</td>
                                <td>@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                                <td>@app.OrganizationUnit</td>
                                <td>@app.ResponsiblePerson</td>
                                <td>@app.Purpose</td>
                                <td>@app.Route</td>
                                <td>
                                    <span class="badge @IndexModel.GetStatusBadgeClass(app.Status)">@IndexModel.GetDisplayName(app.Status)</span>
                                </td>
                                <td style="border-right:none !important">
                                    <a href="#" class="btn btn-sm btn-outline-primary"
                                       onclick="loadApplication(@app.Id)" title="Редактировать">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Заявок не найдено. <a href="#" data-bs-toggle="modal" data-bs-target="#createModal">Создайте первую</a>.
            </div>
        }
    </div>

    <!-- Модальное окно для создания/редактирования -->
    @{
        await Html.RenderPartialAsync("_CreateModal", new Application
        {
            Number = Application.GenerateNumber(),
            ApplicationDate = DateTime.Today,
            Status = ApplicationStatus.CreatedOrModified
        });
    }

    <script>
        function resetFilters() {
            // Очищаем поля дат и организации
            document.querySelector('input[name="DateFrom"]').value = '';
            document.querySelector('input[name="DateTo"]').value = '';
            document.querySelector('input[name="OrganizationUnit"]').value = '';

            // Сбрасываем все чекбоксы статусов
            document.querySelectorAll('input[name="SelectedStatuses"]').forEach(cb => cb.checked = false);

            // Отправляем форму
            document.querySelector('form').submit();
        }

        function selectAllStatuses() {
            // Отмечаем все чекбоксы статусов
            document.querySelectorAll('input[name="SelectedStatuses"]').forEach(cb => cb.checked = true);
            let selectAllInput = document.querySelector('input[name="selectAll"]');
            if (!selectAllInput) {
                selectAllInput = document.createElement('input');
                selectAllInput.type = 'hidden';
                selectAllInput.name = 'selectAll';
                selectAllInput.value = 'true';
                document.querySelector('form').appendChild(selectAllInput);
            } else {
                selectAllInput.value = 'true';
            }
            // Отправляем форму
            document.querySelector('form').submit();
        }

        // Клиентский поиск по таблице
        document.getElementById('searchButton').onclick = filterTable;
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') filterTable();
        });

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(search) ? '' : 'none';
            });
        }

        // При открытии модального окна для новой заявки
        document.getElementById('createModal').addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            // Если кнопка не содержит data-id (новая заявка)
            if (button && !button.getAttribute('data-id')) {
                // Сбрасываем форму
                document.querySelector('#createModal form').reset();
                document.querySelector('#createModal form').action = '/Applications/Create';
                document.querySelector('#createModal input[name="Id"]').value = 0;
                document.querySelector('#createModal .modal-title').textContent = 'СОЗДАНИЕ ЗАЯВКИ';

                // Очищаем выбранных водителя и ТС
                clearSelectedDriver();
                clearSelectedVehicle();

                // Устанавливаем дату сегодня
                var today = new Date().toISOString().split('T')[0];
                document.querySelector('input[name="ApplicationDate"]').value = today;
            }
        });

        function loadApplication(id) {
            console.log('Загрузка заявки ID:', id);

            // Очищаем предыдущие данные перед загрузкой
            clearSelectedDriver();
            clearSelectedVehicle();

            fetch('/Applications/Edit/' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('Загружена заявка:', data);

                    // Проверяем, что данные получены
                    if (!data || !data.id) {
                        throw new Error('Неверные данные от сервера');
                    }

                    // Заполняем основные поля
                    $('#createModal input[name="Id"]').val(data.id);
                    $('#createModal input[name="Number"]').val(data.number || '');

                    if (data.applicationDate) {
                        $('#createModal input[name="ApplicationDate"]').val(data.applicationDate.split('T')[0]);
                    }

                    if (data.tripStart) {
                        $('#createModal input[name="TripStart"]').val(data.tripStart.replace('Z', '').slice(0, 16));
                    } else {
                        $('#createModal input[name="TripStart"]').val('');
                    }

                    if (data.tripEnd) {
                        $('#createModal input[name="TripEnd"]').val(data.tripEnd.replace('Z', '').slice(0, 16));
                    } else {
                        $('#createModal input[name="TripEnd"]').val('');
                    }

                    $('#createModal input[name="OrganizationUnit"]').val(data.organizationUnit || '');
                    $('#createModal input[name="ResponsiblePerson"]').val(data.responsiblePerson || '');
                    $('#createModal input[name="Phone"]').val(data.phone || '');
                    $('#createModal input[name="Purpose"]').val(data.purpose || '');
                    $('#createModal input[name="Passengers"]').val(data.passengers || 1);
                    $('#createModal textarea[name="Route"]').val(data.route || '');
                    $('#createModal textarea[name="Notes"]').val(data.notes || '');

                    // Поля диспетчера
                    $('#createModal input[name="DispatcherName"]').val(data.dispatcherName || '');
                    $('#createModal input[name="DispatcherPhone"]').val(data.dispatcherPhone || '');
                    $('#createModal textarea[name="DispatcherNotes"]').val(data.dispatcherNotes || '');

                    // Водитель
                    if (data.driverName && data.driverName !== 'null') {
                        selectedDriver = {
                            id: data.driverId,
                            name: data.driverName,
                            phone: data.driverPhone
                        };
                        $('#DriverId').val(data.driverId || '');
                        $('#DriverName').val(data.driverName);
                        $('#DriverPhone').val(data.driverPhone || '-');
                        $('#DriverSearchInput').val(data.driverName);
                        $('#SelectedDriverName').text(data.driverName);
                        $('#SelectedDriverPhone').text(data.driverPhone || '-');
                        $('#SelectedDriverInfo').show();
                    } else {
                        $('#SelectedDriverInfo').hide();
                    }

                    // Транспорт
                    if (data.vehicleBrand && data.vehicleBrand !== 'null') {
                        selectedVehicle = {
                            id: data.vehicleId,
                            brand: data.vehicleBrand,
                            plate: data.vehicleNumber,
                            color: data.vehicleColor
                        };
                        $('#VehicleId').val(data.vehicleId || '');
                        $('#VehicleBrand').val(data.vehicleBrand);
                        $('#VehicleNumber').val(data.vehicleNumber || '');
                        $('#VehicleColor').val(data.vehicleColor || '');
                        $('#VehicleSearchInput').val(data.vehicleNumber + ' - ' + data.vehicleBrand);
                        $('#SelectedVehicleInfoText').text(data.vehicleNumber + ' - ' + data.vehicleBrand + ' (' + (data.vehicleColor || '-') + ')');
                        $('#SelectedVehicleInfo').show();
                    } else {
                        $('#SelectedVehicleInfo').hide();
                    }

                    // Настраиваем форму на редактирование
                    var form = $('#createModal form');
                    form.attr('action', '/Applications/Edit/' + id);

                    // Меняем заголовок
                    $('#createModal .modal-title').text('Редактирование заявки №' + (data.number || id));

                    // Показываем модальное окно
                    var modal = new bootstrap.Modal(document.getElementById('createModal'));
                    modal.show();
                })
                .catch(error => {
                    console.error('Ошибка загрузки заявки:', error);
                    alert('Не удалось загрузить данные заявки: ' + error.message);
                });
        }
        
    </script>
</body>
</html>

