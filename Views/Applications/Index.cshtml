@model List<TransportRequestSystem.Models.Application>
@using TransportRequestSystem.Models
@using TransportRequestSystem.Pages.Applications
@using System.Linq

@{
    ViewData["Title"] = "Управление заявками";
    var filter = ViewBag.Filter as ApplicationFilter ?? new ApplicationFilter();
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/applications.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Навигация -->
    <nav class="navbar-custom">
        <div class="container d-flex justify-content-center">
            <a href="#" class="nav-btn">Управление заявками</a>
            <a href="/daily" class="nav-btn">Ежедневная сводка</a>
            <a href="/create" class="nav-btn">Подать заявку</a>
            <a href="#" class="nav-btn">Перечень заявок</a>
        </div>
    </nav>

    <!-- Основной контент -->
    <div class="container mt-4">
        <!-- Шапка с заголовком и поиском -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Управление заявками</h1>
            <div class="d-flex gap-2">
                <!-- Поиск -->
                <div class="input-group" style="width: 300px;">
                    <input type="text" class="form-control" placeholder="Поиск..." id="searchInput">
                    <button class="btn searchButton" type="button" id="searchButton">
                        Поиск
                    </button>
                </div>

                <!-- Кнопка создания -->
                <button type="button" class="btn btn-base"
                        data-bs-toggle="modal"
                        data-bs-target="#createModal">
                    Создать заявку
                </button>
            </div>
        </div>

        <!-- Фильтры -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" asp-action="Index">
                    <div class="row">
                        <!-- Фильтр по дате -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Дата</label>
                            <input type="date" name="DateFrom" class="form-control mb-2" value="@filter.DateFrom?.ToString("yyyy-MM-dd")">
                            <input type="date" name="DateTo" class="form-control" value="@filter.DateTo?.ToString("yyyy-MM-dd")">
                        </div>

                        <!-- Фильтр по организации -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Организация</label>
                            <input type="text" name="OrganizationUnit" class="form-control" value="@filter.OrganizationUnit">
                        </div>

                        <!-- Кнопки управления фильтрами -->
                        <div class="col-md-6 mb-3 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-base">Обновить</button>
                            <button type="submit"
                                    name="reset"
                                    value="true"
                                    class="btn btn-base"
                                    style="background-color:grey;">
                                Сбросить
                            </button>
                        </div>
                    </div>

                    <!-- Фильтр по статусам -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <label class="fw-bold">Статус</label>
                                <button type="submit"
                                        name="selectAll"
                                        value="true"
                                        class="btn btn-base ms-4"
                                        style="width:70px !important; height: 30px !important;">
                                    Все
                                </button>
                            </div>
                            <div class="row">
                                @{
                                    var statusGroups = Enum.GetValues<ApplicationStatus>().Chunk(3).ToList();
                                }
                                @foreach (var group in statusGroups)
                                {
                                    <div class="col-md-4">
                                        @foreach (var status in group)
                                        {
                                            var isChecked = filter.SelectedStatuses?.Contains(status) ?? true;
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="SelectedStatuses" value="@status"
                                                       id="status_@status" @(isChecked ? "checked" : "")>
                                                <label class="form-check-label" for="status_@status">
                                                    @IndexModel.GetDisplayName(status)
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Таблица заявок -->
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Дата</th>
                            <th>Орг. ед.</th>
                            <th>Ответственный</th>
                            <th>Цель</th>
                            <th>Маршрут</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td>@app.Number</td>
                                <td>@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                                <td>@app.OrganizationUnit</td>
                                <td>@app.ResponsiblePerson</td>
                                <td>@app.Purpose</td>
                                <td>@app.Route</td>
                                <td>
                                    <span class="badge @IndexModel.GetStatusBadgeClass(app.Status)">@IndexModel.GetDisplayName(app.Status)</span>
                                </td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-outline-primary"
                                       onclick="loadApplication(@app.Id)" title="Редактировать">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Заявок не найдено. <a href="#" data-bs-toggle="modal" data-bs-target="#createModal">Создайте первую</a>.
            </div>
        }
    </div>

    <!-- Модальное окно для создания/редактирования -->
    @{
        await Html.RenderPartialAsync("_CreateModal", new Application
        {
            Number = Application.GenerateNumber(),
            ApplicationDate = DateTime.Today,
            Status = ApplicationStatus.CreatedOrModified
        });
    }

    <script>
        // Клиентский поиск по таблице
        document.getElementById('searchButton').onclick = filterTable;
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') filterTable();
        });

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(search) ? '' : 'none';
            });
        }

        // Загрузка данных заявки в модальное окно для редактирования
        function loadApplication(id) {
            fetch('/Applications/Edit/' + id)
                .then(response => response.json())
                .then(data => {
                    // Заполняем поля формы
                    Object.keys(data).forEach(key => {
                        const input = document.querySelector(`#createModal [name="${key}"]`);
                        if (input) {
                            if (key === 'applicationDate') {
                                input.value = data[key].substring(0, 10);
                            } else {
                                input.value = data[key] || '';
                            }
                        }
                    });

                    // Обновляем заголовок и адрес отправки
                    document.querySelector('#createModal .modal-title').textContent = 'РЕДАКТИРОВАНИЕ ЗАЯВКИ';
                    document.querySelector('#createModal form').action = '/Applications/Edit/' + id;

                    // Показываем модальное окно
                    new bootstrap.Modal(document.getElementById('createModal')).show();
                });
        }
    </script>
</body>
</html>

