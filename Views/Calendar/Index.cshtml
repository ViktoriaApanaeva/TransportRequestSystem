@{
    ViewData["Title"] = "Календарь заявок";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Транспортные заявки</title>

    <!-- Bootstrap и стили -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <!-- Стили календаря -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
</head>
<body>

    <!-- НАВБАР -->
    @await Html.PartialAsync("_Navbar")
    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <div id="calendar-app">
        <div class="container mt-4">
            <div class="card" style="border: 2px solid #C09C6A; border-radius: 20px; background-color:#FFF3DB;">
                <div class="card-body p-4">
                    <div ref="calendar"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Скрипты -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/ru.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        new Vue({
            el: '#calendar-app',
            data: {
                calendar: null
            },
            methods: {
                async loadEvents(start, end) {
                    try {
                        const response = await axios.get('/api/CalendarApi', {
                            params: { start: start.toISOString(), end: end.toISOString() }
                        });
                        // Преобразуем данные для FullCalendar
                        return response.data.map(event => ({
                            id: event.id,
                            title: event.title,
                            start: event.start,
                            end: event.end,
                            // Убираем фоновый цвет, делаем прозрачным
                            backgroundColor: 'transparent',
                            borderColor: 'transparent',
                            textColor: '#010047',
                            classNames: ['custom-event'],
                            extendedProps: {
                                number: event.number,
                                organizationUnit: event.organizationUnit,
                                route: event.route,
                                driverName: event.driverName,
                                vehicle: event.vehicle,
                                status: event.status,
                                statusName: event.statusName,
                                statusColor: event.color  // Сохраняем цвет статуса
                            }
                        }));
                    } catch (error) {
                        console.error('Ошибка загрузки событий:', error);
                        return [];
                    }
                }
            },
            mounted() {
                const vm = this;
                const calendarEl = this.$refs.calendar;

                this.calendar = new FullCalendar.Calendar(calendarEl, {
                    locale: 'ru',
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek'
                    },
                    buttonText: {
                        today: 'Сегодня',
                        month: 'Месяц',
                        week: 'Неделя'
                    },
                    height: 'auto',
                    firstDay: 1,
                    displayEventTime: false,
                    events: async (info, successCallback) => {
                        const events = await vm.loadEvents(info.start, info.end);
                        successCallback(events);
                    },
                    eventDidMount: (info) => {
                        // Добавляем кружочек слева от текста
                        const statusColor = info.event.extendedProps.statusColor || '#6c757d';
                        const eventTitle = info.event.title;

                        // Очищаем содержимое и добавляем наш кастомный HTML
                        info.el.innerHTML = '';
                        info.el.style.backgroundColor = 'transparent';
                        info.el.style.border = 'none';
                        info.el.style.display = 'flex';
                        info.el.style.alignItems = 'center';
                        info.el.style.gap = '6px';
                        info.el.style.padding = '4px 8px';

                        // Создаем кружочек
                        const circle = document.createElement('span');
                        circle.style.display = 'inline-block';
                        circle.style.width = '8px';
                        circle.style.height = '8px';
                        circle.style.borderRadius = '50%';
                        circle.style.backgroundColor = statusColor;
                        circle.style.flexShrink = '0';

                        // Создаем текст
                        const text = document.createElement('span');
                        text.textContent = eventTitle;
                        text.style.color = '#010047';
                        text.style.fontSize = '11px';
                        text.style.fontWeight = '450';
                        text.style.overflow = 'hidden';
                        text.style.textOverflow = 'ellipsis';
                        text.style.whiteSpace = 'nowrap';

                        info.el.appendChild(circle);
                        info.el.appendChild(text);

                        // Добавляем title для подсказки при наведении
                        info.el.title = `${info.event.extendedProps.statusName || info.event.extendedProps.status}: ${eventTitle}`;
                    },
                    eventClick: (info) => {
                        const event = info.event;
                        alert(` Заявка ${event.extendedProps.number || event.title}\n\n` +
                              ` Дата: ${event.start.toLocaleString()}\n` +
                              ` Организация: ${event.extendedProps.organizationUnit || '—'}\n` +
                              ` Маршрут: ${event.extendedProps.route || '—'}\n` +
                              ` Водитель: ${event.extendedProps.driverName || 'не назначен'}\n` +
                              ` Статус: ${event.extendedProps.statusName || event.extendedProps.status}`);
                    }
                });

                this.calendar.render();
            }
        });
    </script>
</body>
</html>