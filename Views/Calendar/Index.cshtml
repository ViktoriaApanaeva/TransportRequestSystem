@{
    ViewData["Title"] = "Календарь заявок";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Транспортные заявки</title>

    <!-- Bootstrap и стили -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <!-- Стили календаря -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
</head>
<body>

    <!-- НАВБАР -->
    @await Html.PartialAsync("_Navbar")

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <div id="calendar-app">
        <div class="container mt-4">
            <div class="card" style="border: 2px solid #C09C6A; border-radius: 20px; background-color:#FFF3DB;">
                <div class="card-body p-4">
                    <div ref="calendarContainer"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Скрипты -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/ru.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>


    <script>
        const { createApp, ref, onMounted } = Vue;

        const CalendarApp = {
            setup() {
                const calendarContainer = ref(null);
                let calendarInstance = null;

                const loadEvents = async (start, end) => {
                    try {
                        const response = await axios.get('/api/CalendarApi', {
                            params: { start: start.toISOString(), end: end.toISOString() }
                        });
                        return response.data;
                    } catch (error) {
                        console.error('Ошибка загрузки событий:', error);
                        return [];
                    }
                };

                onMounted(() => {
                    if (calendarContainer.value) {
                        calendarInstance = new FullCalendar.Calendar(calendarContainer.value, {
                            locale: 'ru',
                            initialView: 'dayGridMonth',
                            headerToolbar: {
                                left: 'prev,next today',
                                center: 'title',
                                right: 'dayGridMonth,timeGridWeek'
                            },
                            buttonText: {
                                today: 'Сегодня',
                                month: 'Месяц',
                                week: 'Неделя'
                            },
                            height: 'auto',
                            firstDay: 1,
                            displayEventTime: false,
                            events: async (info, successCallback) => {
                                const events = await loadEvents(info.start, info.end);
                                const formattedEvents = events.map(event => ({
                                    id: event.id,
                                    title: event.title,
                                    start: event.start,
                                    end: event.end,
                                    backgroundColor: 'transparent',
                                    borderColor: 'transparent',
                                    extendedProps: {
                                        number: event.number,
                                        organizationUnit: event.organizationUnit,
                                        route: event.route,
                                        driverName: event.driverName,
                                        vehicle: event.vehicle,
                                        status: event.status,
                                        statusName: event.statusName,
                                        statusColor: event.color
                                    }
                                }));
                                successCallback(formattedEvents);
                            },
                            eventDidMount: (info) => {
                                // Получаем цвет статуса
                                const statusColor = info.event.extendedProps.statusColor || '#6c757d';
                                const eventTitle = info.event.title;

                                // Полностью очищаем элемент события
                                while (info.el.firstChild) {
                                    info.el.removeChild(info.el.firstChild);
                                }

                                // Убираем фон 
                                info.el.style.backgroundColor = 'transparent';
                                info.el.style.border = 'none';
                                info.el.style.display = 'flex';
                                info.el.style.alignItems = 'center';
                                info.el.style.padding = '0';

                                // Создаем обертку
                                const wrapper = document.createElement('div');
                                wrapper.className = 'custom-event-wrapper';

                                // Создаем кружочек
                                const circle = document.createElement('div');
                                circle.style.width = '6px';      
                                circle.style.height = '6px';
                                circle.className = 'custom-event-circle';
                                circle.style.backgroundColor = statusColor;
                                circle.style.display = 'inline-block';

                                // Создаем текст
                                const text = document.createElement('span');
                                text.className = 'custom-event-text';
                                text.textContent = eventTitle;

                                // Добавляем элементы в обертку
                                wrapper.appendChild(circle);
                                wrapper.appendChild(text);

                                // Добавляем обертку в событие
                                info.el.appendChild(wrapper);

                                // Добавляем title для подсказки
                                info.el.title = `${info.event.extendedProps.statusName || info.event.extendedProps.status}: ${eventTitle}`;
                            },
                            eventClick: (info) => {
                                const event = info.event;
                                alert(` Заявка ${event.extendedProps.number || event.title}\n\n` +
                                      ` Дата: ${event.start.toLocaleString()}\n` +
                                      ` Организация: ${event.extendedProps.organizationUnit || '—'}\n` +
                                      ` Маршрут: ${event.extendedProps.route || '—'}\n` +
                                      ` Водитель: ${event.extendedProps.driverName || 'не назначен'}\n` +
                                      ` Статус: ${event.extendedProps.statusName || event.extendedProps.status}`);
                            }
                        });

                        calendarInstance.render();
                    }
                });

                return {
                    calendarContainer
                };
            }
        };

        createApp(CalendarApp).mount('#calendar-app');
    </script>
</body>
</html>